{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "AI PR Review Assistant",
          "informationUri": "https://github.com/openai/openai-python/pull/123",
          "rules": [
            {
              "id": "testing.source_without_tests",
              "name": "testing.source_without_tests",
              "shortDescription": {
                "text": "Source files changed without an accompanying test file in this PR."
              },
              "help": {
                "text": "Add or update tests that exercise the changed source behavior."
              },
              "properties": {
                "category": "testing",
                "confidence": "medium"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "testing.source_without_tests",
          "level": "warning",
          "message": {
            "text": "Source files changed without an accompanying test file in this PR. Recommendation: Add or update tests that exercise the changed source behavior."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "openai/api_resources/moderation.py"
                },
                "region": {}
              }
            }
          ],
          "properties": {
            "severity": "medium",
            "confidence": "medium",
            "source": "rule",
            "evidence": "No changed file matched common test naming conventions.",
            "priority_reason": "medium severity; medium confidence; testing impact."
          }
        }
      ]
    }
  ]
}